**/__pycache__/*
tmp
.idea
.venv
**/.DS_Store
.vscode
.dccache

# Sensitive auth files
.env
**/*_auth.json
**/auth/*.json

# Data directories
/data/
# Local data archives/exports at the repo root (can be very large). Anchored to
# the root so a legitimately-tracked zip in a subdir (e.g. a test fixture) still works.
/*.zip

# Log files
logs/
*.log

# Generated
uv.lock
.pytest_cache/

# Benchmark results (timestamped JSON, machine-specific)
benchmarks/results/

# Private domain repos (each has its own .git)
huginn-nav/
huginn-capra/
huginn-jarvis/

# Knowledge graphs may contain customer-confidential data; they belong in the
# private sub-repos above, not in the public scripts/ folder. These patterns
# are a safety net so an accidentally-misrouted extractor output can't be
# `git add`-ed.
scripts/knowledge_graph/*.json
scripts/knowledge_graph/*.cache.json
scripts/knowledge_graph/*.cache.json.*

# Local start script (personal config)
start.sh

# Working / scratch / customer / internal-research docs belong in the mimir wiki repo.
# See ../mimir/plans/consolidate-working-docs-into-mimir.md for the policy.
docs/handover-*.md
docs/*-followups.md
docs/*-plan.md
docs/*-arbeidsplan.md
docs/*-investigation.md
docs/*-report.md
docs/*-fixes.md
docs/*-races.md
docs/blog-*.md
docs/presentasjon-*.md
docs/melosys-*.md
docs/vipps-*
docs/X_*.md
benchmarks/FINDINGS.md
Vipps_*.md
Møtereferat*

# Local-only Claude Code memory (private LLM-session redirect to mimir wiki repo)
CLAUDE.local.md
.claude/worktrees/
